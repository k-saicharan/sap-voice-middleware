# Database — SQLite (dev) or PostgreSQL (production)
DATABASE_URL=sqlite+aiosqlite:///./voice_profiles.db
# DATABASE_URL=postgresql+asyncpg://voice:changeme@localhost:5432/voice_profiles

# API authentication — comma-separated keys; empty = disabled (dev only)
API_KEYS=

# Set to false to require API key on GET /workers/{id}/profile too
PUBLIC_PROFILE_ENDPOINT=true

# Groq Whisper API key — get one free at console.groq.com
GROQ_API_KEY=

# Audio file storage path (Docker volume mount point in production)
AUDIO_STORAGE_PATH=/data/audio

# Speaker embedding model: mock (CI/dev) | speechbrain | pyannote
# IMPORTANT: speaker embeddings are biometric data under GDPR Art. 4(14).
# Ensure a DPIA is completed before enabling speechbrain or pyannote in production.
EMBEDDING_MODEL=mock

# Required only when EMBEDDING_MODEL=pyannote
HUGGINGFACE_TOKEN=

# Postgres password (used by docker-compose.yml)
POSTGRES_PASSWORD=changeme
